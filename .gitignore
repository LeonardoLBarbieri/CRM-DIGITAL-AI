# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ===========================
# VARIAVEIS DE AMBIENTE (SEGURANÇA)
# ===========================
.env
.env.*
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
!.env.example

# ===========================
# DEPENDENCIAS
# ===========================
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ===========================
# NEXT.JS
# ===========================
/.next/
/out/
/build

# ===========================
# TESTES
# ===========================
/coverage

# ===========================
# TYPESCRIPT
# ===========================
*.tsbuildinfo
next-env.d.ts

# ===========================
# LOGS
# ===========================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ===========================
# CERTIFICADOS E CHAVES
# ===========================
*.pem
*.key
*.cert
*.crt
secrets.*

# ===========================
# SISTEMA OPERACIONAL
# ===========================
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ===========================
# EDITORES E IDEs
# ===========================
.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# ===========================
# VERCEL
# ===========================
.vercel

# ===========================
# PRISMA (BANCO DE DADOS)
# ===========================
prisma/*.db
prisma/*.db-journal

# ===========================
# SKILLS DE DESIGNER (LOCAL)
# ===========================
.skills/
.agent/
