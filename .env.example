# ============================================================
# ARQUIVO DE EXEMPLO - Copie este arquivo para .env.local
# e preencha com suas chaves de API reais.
# NUNCA commite o arquivo .env.local no Git!
# ============================================================

# Chave de API da OpenAI (para gerar os roteiros imobiliários persuasivos)
OPENAI_API_KEY="sua_chave_openai_aqui"

# Chaves de API da ElevenLabs (para clonar sua voz)
ELEVENLABS_API_KEY="sua_chave_elevenlabs_aqui"
ELEVENLABS_VOICE_ID="id_da_sua_voz_elevenlabs_aqui"

# Chaves de API da HeyGen (para gerar o vídeo do avatar 4K)
HEYGEN_API_KEY="sua_chave_heygen_aqui"
# ID do seu avatar digital na HeyGen (busque em: GET /v3/avatars/looks)
HEYGEN_AVATAR_ID="id_do_seu_avatar_heygen_aqui"
# ID de voz na HeyGen (opcional — se não informar, HeyGen usa a voz padrão do avatar)
HEYGEN_VOICE_ID="id_da_voz_heygen_aqui"
